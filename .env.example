# GROQ AI API Key
# Dapatkan API key di https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API Key (fallback jika Groq limit/error)
# Dapatkan API key di https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Cloudflare Turnstile Secret Key (dapatkan di dashboard Cloudflare)
# Secret key berbeda dengan site key. Simpan dengan aman.
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Cloudflare Turnstile Site Key (public - untuk client side)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADon_UHtd4lagTDi
